# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# API BigData Corp (para buscar dados complementares)
BIGDATA_ACCESS_TOKEN=your-bigdata-access-token-here
BIGDATA_TOKEN_ID=your-bigdata-token-id-here

# CNPJ.ws API Token (opcional - se não tiver, usa a API pública)
CNPJWS_TOKEN=your-cnpjws-token-here
